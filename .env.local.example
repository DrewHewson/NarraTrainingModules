# Supabase — from `supabase status` (local) or the project's API settings (cloud)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Base URL used for auth redirects / invite links.
# Local: http://localhost:3001   Cloud: https://<your-vercel-domain>
NEXT_PUBLIC_SITE_URL=http://localhost:3001

# Seed accounts (used by `npm run seed:admin` / `seed:test-learner` and by the
# TEST_MODE one-click switcher). Choose your own values.
SEED_ADMIN_EMAIL=admin@narra.test
SEED_ADMIN_PASSWORD=
TEST_LEARNER_EMAIL=learner@narra.test
TEST_LEARNER_PASSWORD=

# TEST-ONLY one-click Admin/Learner switcher. Leave BOTH unset (or not "true")
# in any real production deploy — enabling them exposes an instant
# login-as-admin backdoor for throwaway test environments only.
TEST_MODE=
NEXT_PUBLIC_TEST_MODE=
